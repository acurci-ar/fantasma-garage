# Copiá este archivo a .env.local y completá los valores.
# El proyecto funciona sin estas variables (usa datos de demostración en
# lib/content/seed-data.ts), pero para conectar Supabase real necesitás:

# --- Supabase -------------------------------------------------------------
# Dashboard de Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Nunca exponer con prefijo NEXT_PUBLIC_. Solo se usa en servidor
# (webhooks, tareas admin). No commitear este valor.
SUPABASE_SERVICE_ROLE_KEY=

# --- Sitio ------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=https://fantasmagarage.com

# --- Mercado Pago (próxima etapa: Checkout Pro + webhook) -----------------
# Dashboard de Mercado Pago > Tus integraciones > Credenciales
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# --- YouTube Data API (próxima etapa: playlist automática) ----------------
YOUTUBE_API_KEY=
